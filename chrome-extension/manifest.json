{
  "manifest_version": 3,
  "name": "Career-Ops AI Job Matcher & Scraper",
  "version": "1.3.0",
  "description": "Extract job listings and auto-fill application forms instantly using your Career-Ops Sync Token.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["*://*/*"],
  "action": {
    "default_title": "Career-Ops AI Co-Pilot",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://id.indeed.com/*",
        "*://*.indeed.co.id/*",
        "*://*.glints.com/*",
        "*://*.jobstreet.co.id/*",
        "*://*.jobstreet.com/*",
        "*://*.kalibrr.com/*",
        "*://*.greenhouse.io/*",
        "*://*.lever.co/*",
        "*://*.techinasia.com/*",
        "*://*.karir.com/*",
        "*://*.loker.id/*",
        "*://*.workday.com/*",
        "*://*.myworkdayjobs.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

{
  "manifest_version": 3,
  "name": "Career-Ops AI Job Matcher & Scraper",
  "version": "1.1.0",
  "description": "Extract job listings and auto-fill application forms instantly using Career-Ops Sync Token.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.indeed.com/*",
    "*://id.indeed.com/*",
    "*://*.indeed.co.id/*",
    "*://*.glints.com/*",
    "*://*.jobstreet.co.id/*",
    "*://*.jobstreet.com/*",
    "*://*.kalibrr.com/*",
    "*://*.greenhouse.io/*",
    "*://*.lever.co/*",
    "*://*.techinasia.com/*",
    "*://*.karir.com/*",
    "*://*.loker.id/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/*",
        "*://*.indeed.com/*",
        "*://id.indeed.com/*",
        "*://*.indeed.co.id/*",
        "*://*.glints.com/*",
        "*://*.jobstreet.co.id/*",
        "*://*.jobstreet.com/*",
        "*://*.kalibrr.com/*",
        "*://*.greenhouse.io/*",
        "*://*.lever.co/*",
        "*://*.techinasia.com/*",
        "*://*.karir.com/*",
        "*://*.loker.id/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

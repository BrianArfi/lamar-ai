datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String         @id @default(uuid())
  fullName           String
  email              String         @unique
  passwordHash       String?
  tier               String         @default("free") // "free" | "pro"
  locationPolicy     String         @default("{\"always_allow\": [], \"allow\": [], \"block\": []}")
  salaryTarget       String         @default("{\"min\": 0, \"max\": 0, \"currency\": \"USD\"}")
  targetRoles        String?        // JSON array of target role strings or plain text list
  onboardingComplete Boolean        @default(false)
  syncToken          String?        @unique
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  resumes            Resume[]
  applications       Application[]
  storyBank          Story[]
}

model Resume {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  versionName String   @default("Default")
  cvMarkdown  String
  skills      String   @default("[]") // JSON string of skills array
  isMaster    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName      String
  roleTitle        String
  status           String          @default("Evaluated")
  fitScore         Float
  jobUrl           String?
  location         String?
  workSetting      String?         @default("Onsite") // "Remote" | "Hybrid" | "Onsite"
  hasPdf           Boolean         @default(false)
  notes            String?
  appliedDate      DateTime?
  tailoredCv       String?
  tailoredCvSkills String?
  tailoredAtsScore Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  evaluations      JobEvaluation[]
}

model JobEvaluation {
  id             String      @id @default(uuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId         String
  reportMarkdown String
  legitimacyTier String      @default("Unknown")
  gaps           String      @default("[]") // JSON string of gaps array
  customization  String?
  createdAt      DateTime    @default(now())
}

model Story {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  starSituation String
  starTask      String
  starAction    String
  starResult    String
  reflection    String?
  archetypeTags String   @default("[]") // JSON string of tags array
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


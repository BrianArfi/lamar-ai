datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String         @id @default(uuid())
  fullName           String
  email              String         @unique
  passwordHash       String?
  locationPolicy     String         @default("{\"always_allow\": [], \"allow\": [], \"block\": []}")
  salaryTarget       String         @default("{\"min\": 0, \"max\": 0, \"currency\": \"USD\"}")
  targetRoles        String?        // JSON array of target role strings or plain text list
  onboardingComplete Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  resumes            Resume[]
  applications       Application[]
  storyBank          Story[]
  jobMatches         UserJobMatch[]
}

model Resume {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  versionName String   @default("Default")
  cvMarkdown  String
  skills      String   @default("[]") // JSON string of skills array
  isMaster    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName      String
  roleTitle        String
  status           String          @default("Evaluated")
  fitScore         Float
  jobUrl           String?
  hasPdf           Boolean         @default(false)
  notes            String?
  appliedDate      DateTime?
  tailoredCv       String?
  tailoredCvSkills String?
  tailoredAtsScore Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  evaluations      JobEvaluation[]
}

model JobEvaluation {
  id             String      @id @default(uuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId         String
  reportMarkdown String
  legitimacyTier String      @default("Unknown")
  gaps           String      @default("[]") // JSON string of gaps array
  customization  String?
  createdAt      DateTime    @default(now())
}

model Story {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  starSituation String
  starTask      String
  starAction    String
  starResult    String
  reflection    String?
  archetypeTags String   @default("[]") // JSON string of tags array
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ScrapedJob {
  id          String         @id @default(uuid())
  platform    String         // "Indeed" | "Glints" | "Kalibrr" | "JobStreet"
  externalId  String         @unique
  title       String
  company     String
  location    String?
  description String
  url         String
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  matches     UserJobMatch[]
}

model UserJobMatch {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  scrapedJobId String
  job          ScrapedJob @relation(fields: [scrapedJobId], references: [id], onDelete: Cascade)
  fitScore     Float
  reportText   String?
  createdAt    DateTime   @default(now())

  @@unique([userId, scrapedJobId])
}

model ScraperFailureReport {
  id           String   @id @default(uuid())
  url          String
  host         String   // e.g. "recruitment.peruri.co.id", "indeed.com"
  platform     String?  // e.g. "Indeed", "Glints", "Custom Portal"
  source       String   // "SERVER_SIDE" | "CHROME_EXTENSION"
  failureType  String   // e.g. "SKELETON_DETECTED", "ANTI_BOT_BLOCKED", "SELECTOR_MISSING", "NETWORK_ERROR"
  errorMessage String
  htmlSnippet  String?  // Potongan struktur HTML atau DOM selector yang gagal diekstrak
  createdAt    DateTime @default(now())
}
